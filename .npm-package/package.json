{
  "name": "propelsdlc-copilot-stub",
  "version": "1.2.0",
  "description": "GitHub Copilot configuration stub for PropelSDLC projects",
  "main": "index.js",
  "bin": {
    "propelsdlc-copilot-init": "./bin/init.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "node prepare.js",
    "test": "npm pack --dry-run",
    "prepublishOnly": "npm run prepare && echo 'Publishing propelsdlc-copilot-stub'",
    "publish:npm": "npm publish --access public",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version",
    "clean": "node -e \"const fs=require('fs');['.github','.vscode','.propel','.env.example'].forEach(f=>fs.existsSync(f)&&fs.rmSync(f,{recursive:true,force:true}))\""
  },
  "keywords": [
    "github-copilot",
    "ai-assistant",
    "propelsdlc",
    "sdlc",
    "configuration"
  ],
  "author": "KANINI Software Solutions",
  "license": "SEE LICENSE IN LICENSE",
  "files": [
    ".github",
    ".vscode",
    ".propel",
    ".env.example",
    "README.md",
    "LICENSE",
    "bin",
    "index.js"
  ],
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kanini/PropelIQ-Stub-Copilot.git"
  },
  "homepage": "https://github.com/kanini/PropelIQ-Stub-Copilot#readme",
  "bugs": {
    "email": "support@kanini.com"
  }
}
