{
  "name": "ai-interview-backend",
  "version": "0.1.0",
  "private": true,
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "rimraf dist && tsc",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "load-test:db": "tsx scripts/load-test-db.ts",
    "load-test:indexes": "tsx scripts/load-test-indexes.ts",
    "load-test:audit": "tsx scripts/load-test-audit.ts",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:status": "prisma migrate status",
    "migrate:diff": "prisma migrate diff --from-schema-datamodel prisma/schema.prisma --to-schema-datasource prisma/schema.prisma --exit-code --script",
    "rollback:pre": "tsx scripts/verify-rollback.ts pre",
    "rollback:post": "tsx scripts/verify-rollback.ts post",
    "zero-downtime:test": "tsx scripts/test-zero-downtime-migration.ts",
    "test:rls": "tsx scripts/test-rls.ts",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/auto-instrumentations-node": "0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.221.0",
    "@opentelemetry/resources": "2.10.0",
    "@opentelemetry/sdk-node": "0.221.0",
    "@opentelemetry/semantic-conventions": "1.43.0",
    "@prisma/client": "5.19.1",
    "@upstash/ratelimit": "2.0.5",
    "@upstash/redis": "1.35.6",
    "axios": "^1.7.9",
    "bcrypt": "^5.1.1",
    "compression": "1.8.1",
    "cors": "2.8.5",
    "dotenv": "17.2.1",
    "express": "4.21.2",
    "helmet": "8.1.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "9.3.2",
    "pino-http": "10.3.0",
    "socket.io": "4.8.1",
    "uuid": "11.1.0",
    "zod": "4.1.5"
  },
  "devDependencies": {
    "@supabase/supabase-js": "2.54.0",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "1.8.1",
    "@types/cors": "2.8.19",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "24.3.0",
    "@types/supertest": "6.0.3",
    "@typescript-eslint/eslint-plugin": "8.40.0",
    "@typescript-eslint/parser": "8.40.0",
    "@vitest/coverage-v8": "2.0.5",
    "eslint": "8.57.0",
    "pino-pretty": "11.2.2",
    "prisma": "5.19.1",
    "rimraf": "6.0.1",
    "socket.io-client": "4.8.1",
    "supertest": "7.1.1",
    "tsx": "4.20.4",
    "typescript": "5.9.2",
    "vitest": "2.0.5"
  }
}